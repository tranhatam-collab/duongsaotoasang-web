{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true,
    "worker": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "error"
  },
  "ignorePatterns": ["node_modules/", "dist/", "build/"]
}
