# DSTS Routing v1.1 - Cloudflare Pages
# Cloudflare Pages automatically serves clean URLs from matching HTML files:
# /about -> about.html, /program -> program.html, etc.
# It also automatically renders /404.html for missing assets.
# Do not add /* /404.html 404 here: Pages _redirects does not support 404 rewrites
# and redirects are applied even when a matching asset exists.

# Special route normalization
/programs                         /program                              301
/terms                            /legal#terms                          302
/refund                           /legal#refund                         302
/privacy                          /legal#privacy                        302
/payment-confirmation             /contact?type=payment-confirmation    302

